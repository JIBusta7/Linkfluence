# Supabase — sacá estos valores en Supabase → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-publishable-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# LLM (opcionales — sin estas, la app usa fallbacks determinísticos)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# URL pública de la app — en local podés dejarlo así.
# En Vercel poné tu dominio (ej: https://linkfluence.vercel.app)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Mercado Libre OAuth (opcional). Si lo dejás vacío, sync:catalog usa DummyJSON.
# Para conseguirlo: registrá una app en https://developers.mercadolibre.com.uy
# y completá el flujo OAuth2 para obtener un access_token.
MELI_ACCESS_TOKEN=
