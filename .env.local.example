# Supabase — sacá estos valores en Supabase → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-publishable-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# LLM (opcionales — sin estas, la app usa fallbacks determinísticos)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# URL pública de la app — en local podés dejarlo así.
# En Vercel poné tu dominio (ej: https://linkfluence.vercel.app)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Mercado Libre OAuth (opcional). Si dejás MELI_ACCESS_TOKEN vacío,
# sync:catalog usa DummyJSON como fuente de productos.
#
# Para usar Mercado Libre:
#   1. Registrá una app en https://developers.mercadolibre.com.uy/devcenter
#      con Redirect URI = la URL pública de tu app.
#   2. Completá MELI_CLIENT_ID, MELI_CLIENT_SECRET, MELI_REDIRECT_URI.
#   3. Corré: npm run meli:auth
#   4. Pegá el access_token resultante en MELI_ACCESS_TOKEN.
#   5. Corré: npm run sync:catalog
MELI_CLIENT_ID=
MELI_CLIENT_SECRET=
MELI_REDIRECT_URI=
MELI_ACCESS_TOKEN=
